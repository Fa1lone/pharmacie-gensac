---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "Pharmacie de Gensac-la-Pallue | Charente (16130)",
  description = "Votre pharmacie de proximité à Gensac-la-Pallue, Charente. Ordonnances, vaccination, matériel médical, conseils santé. Tél : 05 45 82 40 12.",
  canonical = "https://pharmacie-gensac.fr/",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/png" href="/logo-rond.png" />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,600;0,700;0,800;1,700;1,800&family=Figtree:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap" rel="stylesheet" />
<script src="https://unpkg.com/@phosphor-icons/web@2.1.1"></script>

<style>
:root{
  --cream:#F7F4EA;--cream-2:#FFFDF7;
  --green-deep:#046A38;--green-vivid:#43B02A;--green-leaf:#97D700;
  --blue-river:#0072CE;--yellow-iris:#FFCD00;--brown-trunk:#623412;
  --text-main:#0D2118;--text-mid:#2c3d32;
  --ease:cubic-bezier(0.16,1,0.3,1);
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{
  font-family:'Figtree',sans-serif;font-size:17px;line-height:1.65;
  background:var(--cream);color:var(--text-main);
  -webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;
  overflow-x:hidden;
}
h1,h2,h3,h4{font-family:'Montserrat',sans-serif;line-height:1.05;}
a{color:inherit;text-decoration:none;}
i[class^="ph"]{display:inline-block;line-height:1;}

/* reveal */
.reveal{opacity:0;transform:translateY(22px);transition:opacity .72s var(--ease),transform .72s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none;}*{animation:none!important;}}

/* hamburger */
.hamburger{display:none;flex-direction:column;justify-content:center;gap:5px;width:40px;height:40px;padding:8px;background:transparent;border:none;cursor:pointer;border-radius:8px;transition:background .2s;}
.hamburger:hover{background:rgba(4,106,56,0.08);}
.hamburger span{display:block;width:22px;height:2px;background:var(--green-deep);border-radius:2px;transition:transform .35s var(--ease),opacity .35s var(--ease);transform-origin:center;}
.hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* mobile menu */
.mobile-menu{display:none;position:fixed;inset:0;z-index:99;background:var(--cream);flex-direction:column;align-items:flex-start;justify-content:center;padding:80px 36px 40px;}
.mobile-menu.open{display:flex;}
.mobile-menu nav a{font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(2rem,7vw,2.8rem);color:var(--text-main);line-height:1.15;display:block;padding:8px 0;opacity:0;transform:translateX(-20px);transition:color .25s var(--ease);}
.mobile-menu.open nav a{animation:menuReveal .5s var(--ease) forwards;}
.mobile-menu.open nav a:nth-child(1){animation-delay:.05s;}
.mobile-menu.open nav a:nth-child(2){animation-delay:.12s;}
.mobile-menu.open nav a:nth-child(3){animation-delay:.19s;}
.mobile-menu.open nav a:nth-child(4){animation-delay:.26s;}
.mobile-menu.open nav a:nth-child(5){animation-delay:.32s;}
@keyframes menuReveal{to{opacity:1;transform:translateX(0);}}
.mobile-menu nav a:hover{color:var(--green-deep);}
.mobile-menu .menu-phone{margin-top:36px;display:inline-flex;align-items:center;gap:10px;background:var(--green-deep);color:var(--cream);font-family:'Montserrat',sans-serif;font-weight:700;font-size:1.1rem;padding:14px 24px;border-radius:999px;opacity:0;}
.mobile-menu.open .menu-phone{animation:menuReveal .5s var(--ease) .38s forwards;}

/* header */
header{position:sticky;top:0;z-index:100;background:rgba(247,244,234,0.94);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(4,106,56,0.08);transition:box-shadow .35s var(--ease);}
header.scrolled{box-shadow:0 2px 24px rgba(4,106,56,0.10);}
.header-inner{max-width:1280px;margin:0 auto;padding:12px 28px;display:flex;align-items:center;justify-content:space-between;gap:24px;}
.brand{display:flex;align-items:center;gap:12px;}
.brand-logo{flex:none;height:48px;width:auto;display:block;object-fit:contain;}
.brand-text{display:flex;flex-direction:column;line-height:1.05;}
.brand-text .b1{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.1rem;color:var(--green-deep);}
.brand-text .b2{font-size:0.58rem;font-weight:600;letter-spacing:0.18em;text-transform:uppercase;color:var(--text-mid);margin-top:2px;}
nav.main-nav{display:flex;align-items:center;gap:28px;}
nav.main-nav a{font-family:'Montserrat',sans-serif;font-size:0.85rem;font-weight:600;color:var(--text-mid);position:relative;padding:4px 0;transition:color .25s var(--ease);}
nav.main-nav a::after{content:"";position:absolute;left:0;bottom:-2px;height:2px;width:100%;background:var(--blue-river);transform:scaleX(0);transform-origin:left;transition:transform .35s var(--ease);}
nav.main-nav a:hover{color:var(--blue-river);}
nav.main-nav a:hover::after,nav.main-nav a.active::after{transform:scaleX(1);}
nav.main-nav a.active{color:var(--green-deep);}
.header-right{display:flex;align-items:center;gap:12px;}
.phone-pill{display:inline-flex;align-items:center;gap:9px;background:var(--green-deep);color:var(--cream);font-family:'Montserrat',sans-serif;font-weight:700;font-size:1rem;padding:10px 20px;border-radius:999px;white-space:nowrap;transition:background .25s var(--ease),transform .2s var(--ease);}
.phone-pill:hover{background:var(--green-vivid);transform:translateY(-1px);}

/* page hero (inner pages) */
.page-hero{
  background:var(--green-deep);
  padding:clamp(80px,8vw,120px) 28px clamp(60px,6vw,90px);
}
.page-hero-inner{max-width:1280px;margin:0 auto;}
.page-eyebrow{
  display:flex;align-items:center;gap:10px;
  font-family:'Montserrat',sans-serif;font-weight:700;
  font-size:0.62rem;text-transform:uppercase;letter-spacing:0.16em;
  color:rgba(247,244,234,0.50);margin-bottom:18px;
}
.page-eyebrow::before{content:"";width:20px;height:2px;background:var(--blue-river);}
.page-hero h1{
  font-weight:800;
  font-size:clamp(2.4rem,5.5vw,5rem);
  letter-spacing:-0.03em;line-height:0.95;
  color:var(--cream);max-width:22ch;
}
.page-hero h1 em{font-style:italic;color:var(--yellow-iris);}
.page-hero .page-subtitle{
  font-size:1rem;line-height:1.7;
  color:rgba(247,244,234,0.72);max-width:52ch;margin-top:20px;
}
.blue-top{height:3px;background:var(--blue-river);}

/* section shell */
.section-wrap{max-width:1280px;margin:0 auto;padding:0 28px;}
.eyebrow{display:flex;align-items:center;gap:12px;font-family:'Montserrat',sans-serif;font-weight:700;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.16em;color:var(--green-deep);margin-bottom:20px;}
.eyebrow::before{content:"";width:28px;height:2px;background:var(--yellow-iris);flex:none;}

/* content sections */
.content-section{padding:clamp(72px,8vw,108px) 0;}
.content-section.bg-cream-2{background:var(--cream-2);}
.content-section.bg-green{background:var(--green-deep);}
.section-h2{font-weight:800;font-size:clamp(2rem,3.8vw,3.2rem);letter-spacing:-0.025em;margin-bottom:40px;}
.section-h2 em{font-style:italic;color:var(--green-deep);}
.section-h2.light em{color:var(--yellow-iris);}
.section-h2.light{color:var(--cream);}

/* cards grid */
.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;}
.card{background:var(--cream-2);border:1px solid rgba(4,106,56,0.09);border-radius:3px;padding:28px 30px;}
.card h3{font-family:'Montserrat',sans-serif;font-weight:700;font-size:1rem;color:var(--text-main);margin-bottom:8px;line-height:1.3;}
.card p{font-size:0.9rem;color:var(--text-mid);line-height:1.6;}
.card-icon{width:40px;height:40px;border-radius:8px;background:rgba(4,106,56,0.07);display:flex;align-items:center;justify-content:center;color:var(--green-deep);font-size:1.1rem;margin-bottom:14px;}

/* contact form */
.form-field{display:flex;flex-direction:column;gap:6px;margin-bottom:18px;}
.form-field label{font-family:'Montserrat',sans-serif;font-size:0.78rem;font-weight:700;color:var(--text-main);letter-spacing:0.04em;}
.form-field input,.form-field textarea,.form-field select{
  font-family:'Figtree',sans-serif;font-size:0.95rem;
  padding:11px 16px;border-radius:3px;
  border:1.5px solid rgba(4,106,56,0.18);
  background:var(--cream-2);color:var(--text-main);
  transition:border-color .25s var(--ease);width:100%;
}
.form-field textarea{min-height:120px;resize:vertical;}
.form-field input:focus,.form-field textarea:focus{outline:none;border-color:var(--blue-river);}
.btn-submit{
  display:inline-flex;align-items:center;gap:10px;
  background:var(--green-deep);color:var(--cream);
  font-family:'Montserrat',sans-serif;font-weight:800;font-size:1rem;
  padding:14px 32px;border-radius:999px;border:none;cursor:pointer;
  transition:background .25s var(--ease),transform .2s var(--ease);
}
.btn-submit:hover{background:var(--green-vivid);transform:translateY(-2px);}

/* footer */
footer{background:var(--green-deep);color:rgba(247,244,234,0.78);padding:64px 28px 40px;}
.footer-inner{max-width:1280px;margin:0 auto;display:flex;flex-wrap:wrap;gap:48px;justify-content:space-between;}
.footer-brand{max-width:300px;}
.footer-logo{display:block;height:48px;width:auto;object-fit:contain;background:white;padding:8px 14px;border-radius:3px;margin-bottom:18px;}
.footer-brand p{font-size:0.88rem;line-height:1.65;color:rgba(247,244,234,0.52);}
.footer-social{display:flex;gap:10px;margin-top:18px;}
.social-ico{width:36px;height:36px;border-radius:8px;background:rgba(247,244,234,0.07);border:1px solid rgba(247,244,234,0.12);display:flex;align-items:center;justify-content:center;color:rgba(247,244,234,0.62);font-size:1rem;transition:background .2s,color .2s,border-color .2s;flex:none;}
.social-ico:hover{background:var(--blue-river);color:#fff;border-color:var(--blue-river);}
.footer-col h4{font-family:'Montserrat',sans-serif;font-weight:700;font-size:0.65rem;text-transform:uppercase;letter-spacing:0.16em;color:var(--yellow-iris);margin-bottom:14px;}
.footer-col p,.footer-col a{display:flex;align-items:center;gap:9px;font-size:0.88rem;color:rgba(247,244,234,0.70);margin-bottom:10px;}
.footer-col a:hover{color:var(--cream);}
.footer-col i{color:var(--green-leaf);font-size:1rem;}
.footer-bottom{max-width:1280px;margin:36px auto 0;padding-top:20px;border-top:1px solid rgba(247,244,234,0.10);font-size:0.75rem;color:rgba(247,244,234,0.38);}

/* mobile sticky */
.mobile-sticky{display:none;position:fixed;bottom:0;left:0;right:0;z-index:200;background:var(--cream-2);border-top:1px solid rgba(4,106,56,0.12);padding:8px 12px calc(8px + env(safe-area-inset-bottom));box-shadow:0 -4px 24px rgba(4,106,56,0.10);}
.sticky-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.sticky-btn{display:flex;flex-direction:column;align-items:center;gap:4px;padding:10px 6px;border-radius:10px;font-family:'Montserrat',sans-serif;font-size:0.72rem;font-weight:700;color:var(--text-mid);text-decoration:none;transition:background .2s,color .2s;}
.sticky-btn i{font-size:1.4rem;}
.sticky-btn:hover{background:rgba(4,106,56,0.06);color:var(--green-deep);}
.sticky-btn.primary{background:var(--green-deep);color:var(--cream);}
.sticky-btn.primary:hover{background:var(--green-vivid);}

/* responsive */
@media(max-width:780px){
  nav.main-nav{display:none;}
  .hamburger{display:flex;}
  .phone-pill{display:none;}
  .mobile-sticky{display:block;}
  footer{padding-bottom:96px;}
  .header-inner{padding:12px 18px;}
  .brand-text .b2{display:none;}
  .cards-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<div class="mobile-menu" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Menu navigation">
  <nav>
    <a href="/">Accueil</a>
    <a href="/la-pharmacie">La pharmacie</a>
    <a href="/produits">Produits &amp; matériel</a>
    <a href="/services">Services</a>
    <a href="/contact">Contactez-nous</a>
  </nav>
  <a class="menu-phone" href="tel:+33545824012">
    <i class="ph-bold ph-phone-call"></i>05 45 82 40 12
  </a>
</div>

<header>
  <div class="header-inner">
    <a class="brand" href="/" aria-label="Pharmacie de Gensac-la-Pallue — Accueil">
      <img class="brand-logo" src="/logo-vertical.png" alt="Logo Pharmacie de Gensac-la-Pallue" width="44" height="52" />
      <span class="brand-text">
        <span class="b1">Pharmacie</span>
        <span class="b2">de Gensac-la-Pallue</span>
      </span>
    </a>
    <nav class="main-nav">
      <a href="/">Accueil</a>
      <a href="/la-pharmacie">La pharmacie</a>
      <a href="/produits">Produits</a>
      <a href="/services">Services</a>
      <a href="/contact">Contact</a>
    </nav>
    <div class="header-right">
      <a class="phone-pill" href="tel:+33545824012">
        <i class="ph-bold ph-phone-call"></i>05 45 82 40 12
      </a>
      <button class="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="blue-top" aria-hidden="true"></div>

<slot />

<footer id="contact-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <img src="/logo-horizontal.png" alt="Pharmacie de Gensac-la-Pallue" class="footer-logo" width="220" height="60" />
      <p>Votre pharmacie de proximité au cœur de la Charente, au service des familles du village depuis plus de 15 ans.</p>
      <div class="footer-social">
        <a class="social-ico" href="#" aria-label="Facebook" target="_blank" rel="noopener"><i class="ph ph-facebook-logo"></i></a>
        <a class="social-ico" href="#" aria-label="Instagram" target="_blank" rel="noopener"><i class="ph ph-instagram-logo"></i></a>
        <a class="social-ico" href="#" aria-label="Google Business" target="_blank" rel="noopener"><i class="ph ph-map-pin"></i></a>
        <a class="social-ico" href="#" aria-label="LinkedIn" target="_blank" rel="noopener"><i class="ph ph-linkedin-logo"></i></a>
      </div>
    </div>
    <div class="footer-col">
      <h4>Horaires</h4>
      <p><i class="ph ph-clock"></i>Lun–Ven · 9h–19h</p>
      <p><i class="ph ph-clock"></i>Samedi · 9h–13h</p>
      <p><i class="ph ph-moon"></i>Dimanche · Pharmacie de garde</p>
    </div>
    <div class="footer-col">
      <h4>Nous joindre</h4>
      <a href="tel:+33545824012"><i class="ph ph-phone-call"></i>05 45 82 40 12</a>
      <a href="mailto:contact@pharmacie-gensac.fr"><i class="ph ph-envelope-simple"></i>contact@pharmacie-gensac.fr</a>
      <p><i class="ph ph-map-pin"></i>Route de Merpins, 16130 Gensac-la-Pallue</p>
    </div>
  </div>
  <div class="footer-bottom">
    © 2026 Pharmacie de Gensac-la-Pallue · Charente · Tous droits réservés
  </div>
</footer>

<nav class="mobile-sticky" aria-label="Actions rapides">
  <div class="sticky-grid">
    <a href="tel:+33545824012" class="sticky-btn primary">
      <i class="ph-bold ph-phone-call"></i>Appeler
    </a>
    <a href="https://maps.google.com/?q=45.6514669,-0.2530952" target="_blank" rel="noopener" class="sticky-btn">
      <i class="ph-light ph-map-pin"></i>Itinéraire
    </a>
    <a href="mailto:contact@pharmacie-gensac.fr" class="sticky-btn">
      <i class="ph-light ph-envelope-simple"></i>Mail
    </a>
  </div>
</nav>

<script>
(function(){
  var hdr=document.querySelector('header');
  window.addEventListener('scroll',function(){hdr.classList.toggle('scrolled',window.scrollY>20);},{passive:true});
})();
(function(){
  var btn=document.querySelector('.hamburger'),menu=document.getElementById('mobile-menu');
  if(!btn||!menu)return;
  function open(){btn.classList.add('open');menu.classList.add('open');btn.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}
  function close(){btn.classList.remove('open');menu.classList.remove('open');btn.setAttribute('aria-expanded','false');document.body.style.overflow='';}
  btn.addEventListener('click',function(){btn.classList.contains('open')?close():open();});
  menu.querySelectorAll('a').forEach(function(a){a.addEventListener('click',close);});
  document.addEventListener('keydown',function(e){if(e.key==='Escape')close();});
})();
(function(){
  var reduce=window.matchMedia('(prefers-reduced-motion:reduce)').matches;
  var els=document.querySelectorAll('.reveal');
  if(reduce){els.forEach(function(e){e.classList.add('in');});return;}
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(entry){
      if(entry.isIntersecting){
        var group=Array.prototype.slice.call(entry.target.parentElement.querySelectorAll('.reveal'));
        var idx=group.indexOf(entry.target);
        setTimeout(function(){entry.target.classList.add('in');},idx>-1?idx*70:0);
        io.unobserve(entry.target);
      }
    });
  },{threshold:0.10,rootMargin:'0px 0px -6% 0px'});
  els.forEach(function(e){io.observe(e);});
})();
</script>
</body>
</html>
