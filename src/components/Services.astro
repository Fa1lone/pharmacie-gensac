---
const services = [
  { icon: "pill", title: "Ordonnances", desc: "Délivrance de médicaments sur prescription, générique compris. Conseils posologie inclus." },
  { icon: "chat-circle-text", title: "Conseils santé", desc: "Entretiens pharmaceutiques, suivi de traitement, orientation vers le bon professionnel." },
  { icon: "syringe", title: "Vaccination", desc: "Grippe, COVID, voyage : vaccins administrés directement à l'officine sur rendez-vous." },
  { icon: "heartbeat", title: "Matériel médical", desc: "Location et vente : béquilles, fauteuils roulants, tensiomètres, et plus." },
  { icon: "person", title: "Orthopédie", desc: "Semelles, genouillères, ceintures lombaires. Conseil personnalisé et pose inclus." },
  { icon: "house", title: "Maintien à domicile", desc: "Préparation des doses, livraison, liens avec infirmiers et médecins traitants." },
  { icon: "baby", title: "Bébé & famille", desc: "Lait infantile, couches, produits de soin. Conseils allaitement et premiers mois." },
  { icon: "leaf", title: "Conseils naturels", desc: "Compléments alimentaires, phytothérapie, huiles essentielles — avec rigueur scientifique." },
];
---

<section id="services" aria-labelledby="services-title">
  <div class="section-inner">
    <div class="section-eyebrow reveal">Ce que nous faisons</div>
    <h2 id="services-title" class="section-title reveal reveal-delay-1">
      Tous vos besoins santé,<br /><em>sous un même toit</em>
    </h2>
    <p class="section-sub reveal reveal-delay-2">
      Médicaments, vaccins, orthopédie, matériel médical, conseils bébé, phytothérapie. Tout se passe ici, avec la même équipe.
    </p>

    <div class="services-grid">
      {services.map((s, i) => (
        <div class={`service-card reveal${i % 4 > 0 ? ` reveal-delay-${i % 4}` : ''}`}>
          <div class="service-icon">
            <ph-icon name={s.icon} size="22" weight="light" aria-hidden="true"></ph-icon>
          </div>
          <h3>{s.title}</h3>
          <p set:html={s.desc}></p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .service-card {
    background: var(--cream-2);
    border: 1px solid var(--border-green);
    border-radius: var(--radius-card);
    padding: 28px 24px;
    transition: transform 0.3s var(--ease-spring), box-shadow 0.3s var(--ease-spring), border-color 0.3s;
    position: relative;
    overflow: hidden;
  }
  .service-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--blue-river), rgba(45,161,217,0));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
    border-radius: 0 0 var(--radius-card) var(--radius-card);
  }
  .service-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); border-color: rgba(45,161,217,0.2); }
  .service-card:hover::after { transform: scaleX(1); }

  .service-icon {
    width: 44px;
    height: 44px;
    background: rgba(9,101,52,0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    color: var(--green-deep);
    transition: background 0.25s;
  }
  .service-card:hover .service-icon { background: rgba(9,101,52,0.14); }

  .service-card h3 {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 8px;
    letter-spacing: -0.01em;
  }
  .service-card p { font-size: 0.85rem; color: var(--text-mid); line-height: 1.55; }

  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } }
</style>
