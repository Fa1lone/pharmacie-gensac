---
import LayoutV2 from '../layouts/LayoutV2.astro';

const categories = [
  { icon: "ph-bed", titre: "Vente & location de matériel médical", desc: "Lits médicalisés, fauteuils roulants, déambulateurs, cannes, béquilles et tout le matériel nécessaire pour votre autonomie à domicile." },
  { icon: "ph-house", titre: "Maintien à domicile", desc: "Location et vente de matériel adapté pour rester chez soi en toute sécurité, avec conseils personnalisés." },
  { icon: "ph-baby", titre: "Vente & location de tire-lait", desc: "Tire-laits électriques double pompe disponibles à la location. Accompagnement personnalisé pour l'allaitement." },
  { icon: "ph-first-aid-kit", titre: "Perfusion", desc: "Matériel de perfusion sur prescription médicale. Conseils et accompagnement à domicile." },
  { icon: "ph-person-simple-walk", titre: "Orthopédie", desc: "Ceintures lombaires, attelles, colliers cervicaux, semelles orthopédiques, genouillères et conseils d'adaptation." },
  { icon: "ph-sock", titre: "Compression veineuse", desc: "Chaussettes, bas et collants de contention. Mesure et adaptation aux recommandations de votre médecin." },
  { icon: "ph-baby-carriage", titre: "Alimentation bébé", desc: "Laits maternisés, laits de croissance, laits spécifiques (APLV, coliques, régurgitations). Conseils personnalisés." },
  { icon: "ph-heart", titre: "Soins maman & bébé", desc: "Soins de la peau, produits de puériculture, biberons, accessoires d'allaitement. Sélection de produits adaptés aux jeunes mamans." },
  { icon: "ph-pill", titre: "Allopathie", desc: "Délivrance de médicaments sur ordonnance et sans ordonnance, conseil pharmaceutique, renouvellement de traitements." },
  { icon: "ph-leaf", titre: "Phytothérapie", desc: "Plantes médicinales, tisanes, gélules végétales et compléments à base de plantes, sélectionnés avec rigueur." },
  { icon: "ph-drop", titre: "Aromathérapie", desc: "Huiles essentielles de qualité thérapeutique, huiles végétales, diffuseurs et conseil d'utilisation." },
  { icon: "ph-circles-three", titre: "Homéopathie", desc: "Granules, doses et complexes homéopathiques. Conseil personnalisé pour les familles et les nourrissons." },
  { icon: "ph-paw-print", titre: "Vétérinaire", desc: "Antiparasitaires, compléments alimentaires et produits de soin pour chiens, chats et animaux domestiques." },
  { icon: "ph-flask", titre: "Compléments nutritionnels oraux", desc: "CNO sur prescription ou en conseil, pour les personnes dénutries, convalescentes ou âgées. Différentes gammes disponibles." },
  { icon: "ph-sparkle", titre: "Soins dermatologiques", desc: "Crèmes médicales, traitements de la peau sensible, eczéma, psoriasis, acné. Marques dermatologiques conseillées." },
  { icon: "ph-sunglasses", titre: "Soins cosmétiques", desc: "Crèmes hydratantes, soins visage et corps, protection solaire. Sélection de marques dermatologiques et naturelles." },
  { icon: "ph-person", titre: "Hygiène corps & intime", desc: "Produits d'hygiène intime, soins intimes, protections féminines, produits d'incontinence." },
  { icon: "ph-scissors", titre: "Soins capillaires", desc: "Shampoings médicaux, lotions antipelliculaires, traitements antipoux, masques capillaires." },
  { icon: "ph-hand-waving", titre: "Soins corps", desc: "Huiles, baumes, laits corporels. Sélection orientée bien-être et efficacité." },
  { icon: "ph-flower", titre: "Onglerie & pédicurie", desc: "Soins des ongles, traitement des mycoses, produits anti-cors, chaussettes de compression, conseils podologiques." },
  { icon: "ph-tooth", titre: "Hygiène bucco-dentaire", desc: "Brosses à dents, dentifrices médicaux, bains de bouche, fils dentaires, protège-dents." },
  { icon: "ph-shoe-prints", titre: "Podologie de série & chaussures orthopédiques", desc: "Semelles de confort, orthèses plantaires de série, chaussures orthopédiques adaptées aux pieds difficiles." },
];
---
<LayoutV2
  title="Produits & matériel médical | Pharmacie de Gensac-la-Pallue"
  description="Découvrez l'offre complète de la Pharmacie de Gensac-la-Pallue : matériel médical, orthopédie, bébé, aromathérapie, phytothérapie, soins cosmétiques et bien plus."
  canonical="https://pharmacie-gensac.fr/produits"
>
<style>
.cat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:20px;margin-top:40px;}
.cat-card{
  background:var(--cream-2);border:1px solid rgba(4,106,56,0.09);border-radius:3px;
  padding:24px 26px;display:flex;align-items:flex-start;gap:16px;
  transition:transform .25s var(--ease),box-shadow .25s var(--ease);
}
.cat-card:hover{transform:translateY(-3px);box-shadow:0 12px 32px rgba(4,106,56,0.10);}
.cat-ico{
  width:40px;height:40px;flex:none;border-radius:8px;
  background:rgba(4,106,56,0.07);
  display:flex;align-items:center;justify-content:center;
  color:var(--green-deep);font-size:1.2rem;
}
.cat-body h3{font-family:'Montserrat',sans-serif;font-weight:700;font-size:0.92rem;color:var(--text-main);margin-bottom:5px;line-height:1.3;}
.cat-body p{font-size:0.83rem;color:var(--text-mid);line-height:1.6;}
.notice{
  background:var(--blue-river);color:#fff;
  padding:clamp(40px,4vw,60px) 28px;
}
.notice-inner{max-width:1280px;margin:0 auto;display:flex;align-items:center;gap:28px;flex-wrap:wrap;}
.notice-text h3{font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(1.2rem,2.5vw,1.8rem);color:#fff;margin-bottom:8px;letter-spacing:-0.01em;}
.notice-text p{font-size:0.93rem;color:rgba(255,255,255,0.80);max-width:58ch;line-height:1.65;}
.notice-btn{display:inline-flex;align-items:center;gap:10px;background:#fff;color:var(--blue-river);font-family:'Montserrat',sans-serif;font-weight:800;font-size:0.9rem;padding:12px 24px;border-radius:999px;white-space:nowrap;flex:none;transition:transform .25s var(--ease);}
.notice-btn:hover{transform:translateY(-2px);}
@media(max-width:780px){
  .notice-inner{flex-direction:column;align-items:flex-start;}
}
</style>

<section class="page-hero">
  <div class="page-hero-inner">
    <div class="page-eyebrow">Notre offre</div>
    <h1>Produits &amp; <em>matériel médical</em></h1>
    <p class="page-subtitle">Une sélection complète de produits de santé, de bien-être et de matériel médical pour toute la famille.</p>
  </div>
</section>

<section class="notice">
  <div class="notice-inner">
    <div class="notice-text reveal">
      <h3>Un conseil, une question sur un produit ?</h3>
      <p>Notre équipe est à votre disposition pour vous orienter vers le produit adapté à votre situation. N'hésitez pas à nous appeler ou à venir en pharmacie.</p>
    </div>
    <a class="notice-btn" href="tel:+33545824012">
      <i class="ph ph-phone-call"></i>Nous appeler
    </a>
  </div>
</section>

<section class="content-section">
  <div class="section-wrap">
    <div class="eyebrow reveal">Toutes les catégories</div>
    <h2 class="section-h2 reveal">Ce que vous trouvez <em>chez nous</em></h2>
    <div class="cat-grid">
      {categories.map((cat, i) => (
        <div class={`cat-card reveal`}>
          <div class="cat-ico"><i class={`ph ${cat.icon}`}></i></div>
          <div class="cat-body">
            <h3>{cat.titre}</h3>
            <p>{cat.desc}</p>
          </div>
        </div>
      ))}
    </div>
    <p style="margin-top:32px;font-size:0.85rem;color:var(--text-mid);font-style:italic;">
      Cette liste est indicative et sera complétée avec les catégories et marques exactes proposées par la pharmacie après la reprise au 1er août 2026.
    </p>
  </div>
</section>

</LayoutV2>
